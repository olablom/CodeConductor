{
    "include": [
        ".",
        "data/generated"
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        ".venv"
    ],
    "venvPath": ".",
    "venv": ".venv",
    "extraPaths": [
        "./.venv/Lib/site-packages",
        "./data/generated"
    ],
    "pythonVersion": "3.11",
    "typeCheckingMode": "off",
    "useLibraryCodeForTypes": true,
    "reportMissingImports": "warning",
    "reportMissingTypeStubs": false
} 